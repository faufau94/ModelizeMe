// schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

/////////////////////
// ENUMS
/////////////////////

/// Rôle d’un user dans un workspace
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

/// Type de diagramme (existant)
enum ModelType {
  MCD
  MLD
  MPD
}

/// Sur quoi porte l’annotation
enum AnnotationTargetType {
  TABLE
  RELATION
}

/////////////////////
// USER & AUTH
/////////////////////

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password          String?
  first_name        String?
  name              String?
  image             String?
  provider          String?
  providerAccountId String?
  createdAt         DateTime @default(now())

  // --- WORKSPACE & TEAMS ---
  workspaceMemberships WorkspaceMember[] // workspaces où il a un rôle
  teamMemberships      TeamMember[] // équipes dont il est membre

  // --- MODELS & GALERIES ---
  dataModels     Model[] // modèles qu’il a créés
  linkedAccounts LinkedAccount[] // connexions externes
  galleryEntries Galery[] // galeries associées à ses modèles

  // --- ANNOTATIONS ---
  annotations Annotation[] // commentaires/annotations qu’il a postés

  workspacesOwned Workspace[] @relation("WorkspaceOwner")

  @@map("users")
}

/////////////////////
// WORKSPACES
/////////////////////

model Workspace {
  id         Int      @id @default(autoincrement())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  ownerId Int
  owner   User @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  members    WorkspaceMember[] // OWNER, ADMIN, MEMBER
  teams      Team[] // équipes dans le workspace
  dataModels Model[] // modèles créés au scope du workspace
}

model WorkspaceMember {
  id              Int           @id @default(autoincrement())
  userId          Int
  workspaceId     Int
  role            WorkspaceRole @default(MEMBER)
  canViewAllTeams Boolean       @default(false)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

/////////////////////
// TEAMS
/////////////////////

model Team {
  id         Int      @id @default(autoincrement())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members    TeamMember[]
  dataModels Model[] // modèles propres à cette équipe
}

model TeamMember {
  id            Int     @id @default(autoincrement())
  userId        Int
  teamId        Int
  canViewOthers Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

/////////////////////
// MODELS (DIAGRAMMES)
/////////////////////

model Model {
  id          Int       @id @default(autoincrement())
  reference   String    @default(uuid())
  name        String
  description String?
  locked      Boolean   @default(false)
  nodes       Json      @default("[]")
  edges       Json      @default("[]")
  type        ModelType @default(MCD)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Scope : workspace + (optionnellement) team
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      Int?
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Auteur
  authorId Int?
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Relations existantes
  Galery      Galery[]
  // Nouvelles annotations
  annotations Annotation[]

  @@map("models")
}

model Galery {
  id         Int      @id @default(autoincrement())
  modelId    Int
  model      Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("galeries")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Galery    Galery[]

  @@map("categories")
}

model LinkedAccount {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  providerId   String
  accessToken  String
  refreshToken String?
  username     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, providerId])
  @@map("linked_accounts")
}

/////////////////////
// ANNOTATIONS
/////////////////////

model Annotation {
  id         Int                  @id @default(autoincrement())
  content    String
  targetType AnnotationTargetType
  targetId   String // identifiant logique de la table ou relation annotée

  modelId Int
  model   Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  authorId Int?
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("annotations")
}
