// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  password  String?
  first_name  String?
  name  String?
  image String?
  provider String?
  providerAccountId String?
  linkedAccounts LinkedAccount[] // Relation vers les comptes liés
  models Model[]
}

model Model {
  id        Int     @id @default(autoincrement())
  name      String
  nodes     Json   @default("[]")
  edges     Json   @default("[]")
  type      ModelType @default(MCD)
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())
}

model LinkedAccount {
  id            Int      @id @default(autoincrement())
  user          User     @relation(fields: [userId], references: [id])
  userId        Int
  provider      String   // e.g., 'github', 'gitlab'
  providerId    String   // Identifiant unique sur le provider
  accessToken   String   // Jeton d'accès pour l'API du provider
  refreshToken  String?  // Jeton de rafraîchissement (optionnel)
  username      String?  // Nom d'utilisateur sur le provider
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, providerId]) // Assure qu'un même compte ne soit lié qu'une seule fois
}

enum ModelType {
  MCD
  MLD
  MPD
}
