// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int             @id @default(autoincrement())
  email             String          @unique
  password          String?
  first_name        String?
  name              String?
  image             String?
  provider          String?
  providerAccountId String?
  linkedAccounts    LinkedAccount[] // Relation vers les comptes liés
  models            Model[]

  @@map("users")
}

model Model {
  id        Int       @id @default(autoincrement())
  name      String
  nodes     Json      @default("[]")
  edges     Json      @default("[]")
  type      ModelType @default(MCD)
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  Galery    Galery[]

  @@map("models")
}

model Galery {
  id         Int      @id @default(autoincrement())
  model      Model    @relation(fields: [modelId], references: [id])
  modelId    Int
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("galeries")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Galery    Galery[]

  @@map("categories")
}

model LinkedAccount {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  provider     String // e.g., 'github', 'gitlab'
  providerId   String // Identifiant unique sur le provider
  accessToken  String // Jeton d'accès pour l'API du provider
  refreshToken String? // Jeton de rafraîchissement (optionnel)
  username     String? // Nom d'utilisateur sur le provider
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, providerId])
  @@map("linked_accounts")
}

enum ModelType {
  MCD
  MLD
  MPD
}
