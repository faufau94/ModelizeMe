<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle — Gestion de Restaurant
  Fonctionnalités couvertes :
    - Types : Time, DateTime, Boolean, Float, Decimal
    - Propriétés portées sur ternaire (quantite, prix_unitaire sur "composer")
    - Association ternaire avec propriétés portées
    - Association réflexive : Plat "accompagner" Plat (suggestions d'accompagnement)
    - Associations simples variées
-->
<model name="Gestion de Restaurant">

  <entities>

    <entity name="Serveur" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="date_embauche" type="Date" nullable="false"/>
      <property name="actif" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Table" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="numero" type="Integer" nullable="false"/>
      <property name="capacite" type="Integer" nullable="false"/>
      <property name="emplacement" type="String" nullable="true"/>
      <property name="disponible" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Client" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="email" type="String" nullable="true"/>
      <property name="allergies" type="Text" nullable="true"/>
      <property name="fidele" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Reservation" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_reservation" type="Date" nullable="false"/>
      <property name="heure" type="Time" nullable="false"/>
      <property name="nombre_convives" type="Integer" nullable="false"/>
      <property name="statut" type="String" nullable="false"/>
    </entity>

    <entity name="Commande" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_heure" type="DateTime" nullable="false"/>
      <property name="statut" type="String" nullable="false"/>
      <property name="montant_total" type="Decimal" nullable="false"/>
      <property name="pourboire" type="Decimal" nullable="true"/>
    </entity>

    <entity name="Plat" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="prix" type="Decimal" nullable="false"/>
      <property name="categorie" type="String" nullable="false"/>
      <property name="calories" type="Float" nullable="true"/>
      <property name="vegetarien" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Ingredient" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="unite" type="String" nullable="false"/>
      <property name="stock" type="Float" nullable="false"/>
      <property name="allergene" type="Boolean" nullable="false"/>
    </entity>

  </entities>

  <relationships>

    <!-- Un client fait une réservation -->
    <relationship name="reserver"
                  source="Client" target="Reservation"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une réservation concerne une table -->
    <relationship name="attribuer"
                  source="Table" target="Reservation"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un serveur gère une table -->
    <relationship name="gerer"
                  source="Serveur" target="Table"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une commande est liée à une table -->
    <relationship name="lier"
                  source="Table" target="Commande"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un serveur prend une commande -->
    <relationship name="prendre"
                  source="Serveur" target="Commande"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une commande contient des plats (avec quantité) -->
    <relationship name="contenir"
                  source="Commande" target="Plat"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="quantite" type="Integer" nullable="false"/>
      <property name="prix_applique" type="Decimal" nullable="false"/>
      <property name="note_speciale" type="String" nullable="true"/>
    </relationship>

    <!-- Un plat nécessite des ingrédients (avec quantité) -->
    <relationship name="necessiter"
                  source="Plat" target="Ingredient"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="quantite_necessaire" type="Float" nullable="false"/>
    </relationship>

    <!-- Plat accompagné par un autre plat (réflexive) -->
    <relationship name="accompagner"
                  source="Plat" target="Plat"
                  sourceCardinality="0,N" targetCardinality="0,N"
                  loopbackSide="bottom"/>

  </relationships>

  <ternary-associations>

    <!-- Un serveur sert un plat à une table (avec heure de service) -->
    <ternary-association name="servir">
      <participant entity="Serveur" cardinality="0,N"/>
      <participant entity="Plat"    cardinality="0,N"/>
      <participant entity="Table"   cardinality="0,N"/>
      <property name="heure_service" type="DateTime" nullable="false"/>
      <property name="quantite" type="Integer" nullable="false"/>
    </ternary-association>

  </ternary-associations>

</model>
