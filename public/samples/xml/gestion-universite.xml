<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle — Gestion Universitaire
  Fonctionnalités couvertes :
    - Types : Time, DateTime, Boolean, Float, Integer
    - Cardinalité 1,N (un département a au moins 1 professeur)
    - Association ternaire avec CIF : Etudiant × Cours × Semestre → "inscrire" (CIF sur Semestre)
    - Association ternaire sans CIF : Professeur × Salle × Cours → "planifier"
    - Association réflexive : Cours "prerequis de" Cours
    - Association N,N avec propriétés portées (noter)
-->
<model name="Gestion Universitaire">

  <entities>

    <entity name="Etudiant" timestamps="true" softDeletes="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="matricule" type="String" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="date_naissance" type="Date" nullable="false"/>
      <property name="boursier" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Professeur" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="specialite" type="String" nullable="false"/>
      <property name="grade" type="String" nullable="false"/>
      <property name="date_recrutement" type="Date" nullable="false"/>
    </entity>

    <entity name="Cours" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="code" type="String" nullable="false"/>
      <property name="intitule" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="credits" type="Integer" nullable="false"/>
      <property name="volume_horaire" type="Integer" nullable="false"/>
      <property name="obligatoire" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Departement" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="code" type="String" nullable="false"/>
      <property name="directeur" type="String" nullable="true"/>
    </entity>

    <entity name="Salle" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="numero" type="String" nullable="false"/>
      <property name="batiment" type="String" nullable="false"/>
      <property name="capacite" type="Integer" nullable="false"/>
      <property name="equipement_video" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Semestre" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="annee" type="Integer" nullable="false"/>
      <property name="numero" type="Integer" nullable="false"/>
      <property name="date_debut" type="Date" nullable="false"/>
      <property name="date_fin" type="Date" nullable="false"/>
    </entity>

  </entities>

  <relationships>

    <!-- Un département regroupe des professeurs (au moins 1) -->
    <relationship name="regrouper"
                  source="Departement" target="Professeur"
                  sourceCardinality="1,1" targetCardinality="1,N"/>

    <!-- Un département propose des cours -->
    <relationship name="proposer"
                  source="Departement" target="Cours"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un professeur enseigne des cours -->
    <relationship name="enseigner"
                  source="Professeur" target="Cours"
                  sourceCardinality="0,N" targetCardinality="0,N"/>

    <!-- Un étudiant note un cours (évaluation pédagogique) -->
    <relationship name="evaluer"
                  source="Etudiant" target="Cours"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="note_examen" type="Float" nullable="false"/>
      <property name="note_td" type="Float" nullable="true"/>
      <property name="moyenne" type="Float" nullable="false"/>
      <property name="session" type="String" nullable="false"/>
    </relationship>

    <!-- Cours prérequis d'un autre (réflexive) -->
    <relationship name="prerequis"
                  source="Cours" target="Cours"
                  sourceCardinality="0,N" targetCardinality="0,N"
                  loopbackSide="right"/>

  </relationships>

  <ternary-associations>

    <!-- Un étudiant s'inscrit à un cours pour un semestre (CIF sur Semestre) -->
    <ternary-association name="inscrire" cif="Semestre">
      <participant entity="Etudiant" cardinality="0,N"/>
      <participant entity="Cours"    cardinality="0,N"/>
      <participant entity="Semestre" cardinality="0,N"/>
    </ternary-association>

    <!-- Un professeur donne un cours dans une salle (planification) -->
    <ternary-association name="planifier">
      <participant entity="Professeur" cardinality="0,N"/>
      <participant entity="Salle"      cardinality="0,N"/>
      <participant entity="Cours"      cardinality="0,N"/>
      <property name="jour" type="String" nullable="false"/>
      <property name="heure_debut" type="Time" nullable="false"/>
      <property name="heure_fin" type="Time" nullable="false"/>
    </ternary-association>

  </ternary-associations>

</model>
