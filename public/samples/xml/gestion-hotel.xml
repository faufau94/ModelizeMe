<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle — Gestion Hôtelière
  Fonctionnalités couvertes :
    - Types : DateTime, Time, Boolean, Decimal, Float, Integer
    - Cardinalité 1,N (un hôtel a au moins 1 chambre)
    - Association ternaire avec CIF : Client × Chambre × Prestation → "consommer" (CIF sur Prestation)
    - Association N,N avec propriétés portées
    - Association réflexive : Employe "supervise" Employe
-->
<model name="Gestion Hôtelière">

  <entities>

    <entity name="Hotel" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="adresse" type="Text" nullable="false"/>
      <property name="ville" type="String" nullable="false"/>
      <property name="etoiles" type="Integer" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="email" type="String" nullable="true"/>
    </entity>

    <entity name="Chambre" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="numero" type="String" nullable="false"/>
      <property name="etage" type="Integer" nullable="false"/>
      <property name="type" type="String" nullable="false"/>
      <property name="prix_nuit" type="Decimal" nullable="false"/>
      <property name="superficie" type="Float" nullable="true"/>
      <property name="disponible" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Client" timestamps="true" softDeletes="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="passeport" type="String" nullable="true"/>
      <property name="vip" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Reservation" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_arrivee" type="Date" nullable="false"/>
      <property name="date_depart" type="Date" nullable="false"/>
      <property name="heure_checkin" type="Time" nullable="true"/>
      <property name="heure_checkout" type="Time" nullable="true"/>
      <property name="montant_total" type="Decimal" nullable="false"/>
      <property name="statut" type="String" nullable="false"/>
      <property name="petit_dejeuner" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Employe" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="poste" type="String" nullable="false"/>
      <property name="date_embauche" type="Date" nullable="false"/>
      <property name="salaire" type="Decimal" nullable="false"/>
    </entity>

    <entity name="Prestation" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="prix" type="Decimal" nullable="false"/>
      <property name="categorie" type="String" nullable="true"/>
    </entity>

  </entities>

  <relationships>

    <!-- Un hôtel possède des chambres (au moins 1) -->
    <relationship name="posseder"
                  source="Hotel" target="Chambre"
                  sourceCardinality="1,1" targetCardinality="1,N"/>

    <!-- Un client effectue des réservations -->
    <relationship name="effectuer"
                  source="Client" target="Reservation"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une réservation porte sur une chambre -->
    <relationship name="porter"
                  source="Chambre" target="Reservation"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un employé travaille dans un hôtel -->
    <relationship name="travailler"
                  source="Hotel" target="Employe"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un employé supervise d'autres employés (réflexive) -->
    <relationship name="superviser"
                  source="Employe" target="Employe"
                  sourceCardinality="0,1" targetCardinality="0,N"
                  loopbackSide="right"/>

    <!-- Un client évalue un hôtel -->
    <relationship name="evaluer"
                  source="Client" target="Hotel"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="note" type="Integer" nullable="false"/>
      <property name="commentaire" type="Text" nullable="true"/>
      <property name="date_evaluation" type="DateTime" nullable="false"/>
    </relationship>

  </relationships>

  <ternary-associations>

    <!-- Un client consomme une prestation dans une chambre (CIF sur Prestation) -->
    <ternary-association name="consommer" cif="Prestation">
      <participant entity="Client"     cardinality="0,N"/>
      <participant entity="Chambre"    cardinality="0,N"/>
      <participant entity="Prestation" cardinality="0,N"/>
    </ternary-association>

  </ternary-associations>

</model>
