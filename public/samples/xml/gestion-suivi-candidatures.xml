<?xml version="1.0" encoding="UTF-8"?>
<model name="Gestion de Suivi de Candidatures">
  <entities>
    <entity name="Candidat" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="adresse" type="String" nullable="true"/>
      <property name="linkedin" type="String" nullable="true"/>
      <property name="portfolio" type="String" nullable="true"/>
    </entity>

    <entity name="Entreprise" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="secteur" type="String" nullable="true"/>
      <property name="taille" type="String" nullable="true"/>
      <property name="site_web" type="String" nullable="true"/>
      <property name="description" type="Text" nullable="true"/>
    </entity>

    <entity name="OffreEmploi" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="titre" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="type_contrat" type="String" nullable="false"/>
      <property name="localisation" type="String" nullable="true"/>
      <property name="teletravail" type="Boolean" nullable="false"/>
      <property name="salaire_min" type="Decimal" nullable="true"/>
      <property name="salaire_max" type="Decimal" nullable="true"/>
      <property name="date_publication" type="Date" nullable="true"/>
      <property name="date_cloture" type="Date" nullable="true"/>
      <property name="url_offre" type="String" nullable="true"/>
    </entity>

    <entity name="Candidature" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_envoi" type="Date" nullable="false"/>
      <property name="statut" type="String" nullable="false"/>
      <property name="source" type="String" nullable="true"/>
      <property name="notes" type="Text" nullable="true"/>
      <property name="priorite" type="String" nullable="true"/>
    </entity>

    <entity name="Entretien" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_heure" type="DateTime" nullable="false"/>
      <property name="type" type="String" nullable="false"/>
      <property name="format" type="String" nullable="false"/>
      <property name="lieu_ou_lien" type="String" nullable="true"/>
      <property name="notes_preparation" type="Text" nullable="true"/>
      <property name="notes_retour" type="Text" nullable="true"/>
      <property name="resultat" type="String" nullable="true"/>
    </entity>

    <entity name="Contact" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="poste" type="String" nullable="true"/>
      <property name="email" type="String" nullable="true"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="linkedin" type="String" nullable="true"/>
    </entity>

    <entity name="Document" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="type" type="String" nullable="false"/>
      <property name="url" type="String" nullable="false"/>
      <property name="version" type="String" nullable="true"/>
    </entity>

    <entity name="Competence" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="categorie" type="String" nullable="true"/>
    </entity>
  </entities>

  <relationships>
    <!-- Un candidat soumet des candidatures -->
    <relationship name="soumettre" source="Candidat" target="Candidature"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une candidature concerne une offre d'emploi -->
    <relationship name="postuler" source="Candidature" target="OffreEmploi"
                  sourceCardinality="0,N" targetCardinality="1,1"/>

    <!-- Une offre est publiée par une entreprise -->
    <relationship name="publier" source="Entreprise" target="OffreEmploi"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Une candidature génère des entretiens -->
    <relationship name="planifier" source="Candidature" target="Entretien"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un contact appartient à une entreprise -->
    <relationship name="appartenir" source="Contact" target="Entreprise"
                  sourceCardinality="0,N" targetCardinality="1,1"/>

    <!-- Un entretien est conduit par un contact -->
    <relationship name="conduire" source="Contact" target="Entretien"
                  sourceCardinality="0,N" targetCardinality="0,N"/>

    <!-- Une candidature est accompagnée de documents -->
    <relationship name="joindre" source="Candidature" target="Document"
                  sourceCardinality="0,N" targetCardinality="0,N"/>

    <!-- Un candidat possède des compétences -->
    <relationship name="posseder" source="Candidat" target="Competence"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="niveau" type="String" nullable="false"/>
    </relationship>

    <!-- Une offre requiert des compétences -->
    <relationship name="requierir" source="OffreEmploi" target="Competence"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="obligatoire" type="Boolean" nullable="false"/>
    </relationship>
  </relationships>
</model>
