<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle — Gestion de Flotte de Véhicules
  Fonctionnalités couvertes :
    - Types : DateTime, Time, Boolean, Float, Decimal, Integer
    - Cardinalité 0,1 (un véhicule a 0 ou 1 conducteur assigné actuellement)
    - Association ternaire sans CIF : Conducteur × Vehicule × Trajet → "effectuer"
    - Associations N,N avec propriétés portées (entretenir)
    - Association réflexive : Vehicule "remorquer" Vehicule
    - softDeletes sur entités
-->
<model name="Gestion de Flotte de Véhicules">

  <entities>

    <entity name="Vehicule" timestamps="true" softDeletes="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="immatriculation" type="String" nullable="false"/>
      <property name="marque" type="String" nullable="false"/>
      <property name="modele" type="String" nullable="false"/>
      <property name="annee" type="Integer" nullable="false"/>
      <property name="kilometrage" type="Float" nullable="false"/>
      <property name="carburant" type="String" nullable="false"/>
      <property name="en_service" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Conducteur" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="permis" type="String" nullable="false"/>
      <property name="date_permis" type="Date" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="disponible" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Trajet" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="depart" type="String" nullable="false"/>
      <property name="arrivee" type="String" nullable="false"/>
      <property name="date_depart" type="DateTime" nullable="false"/>
      <property name="date_arrivee" type="DateTime" nullable="true"/>
      <property name="distance_km" type="Float" nullable="false"/>
      <property name="cout_carburant" type="Decimal" nullable="true"/>
    </entity>

    <entity name="Garage" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="adresse" type="Text" nullable="false"/>
      <property name="telephone" type="String" nullable="false"/>
      <property name="agree" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Entretien" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_entretien" type="Date" nullable="false"/>
      <property name="type" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="cout" type="Decimal" nullable="false"/>
      <property name="prochain_km" type="Float" nullable="true"/>
    </entity>

    <entity name="Assurance" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="numero_contrat" type="String" nullable="false"/>
      <property name="compagnie" type="String" nullable="false"/>
      <property name="type_couverture" type="String" nullable="false"/>
      <property name="date_debut" type="Date" nullable="false"/>
      <property name="date_fin" type="Date" nullable="false"/>
      <property name="prime_annuelle" type="Decimal" nullable="false"/>
    </entity>

  </entities>

  <relationships>

    <!-- Un conducteur est actuellement assigné à un véhicule (0 ou 1) -->
    <relationship name="assigner"
                  source="Conducteur" target="Vehicule"
                  sourceCardinality="0,1" targetCardinality="0,1"/>

    <!-- Un véhicule est couvert par des assurances -->
    <relationship name="couvrir"
                  source="Vehicule" target="Assurance"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un véhicule subit des entretiens -->
    <relationship name="subir"
                  source="Vehicule" target="Entretien"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un garage réalise des entretiens -->
    <relationship name="realiser"
                  source="Garage" target="Entretien"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un véhicule peut remorquer un autre véhicule (réflexive) -->
    <relationship name="remorquer"
                  source="Vehicule" target="Vehicule"
                  sourceCardinality="0,1" targetCardinality="0,N"
                  loopbackSide="bottom"/>

  </relationships>

  <ternary-associations>

    <!-- Un conducteur effectue un trajet avec un véhicule -->
    <ternary-association name="effectuer">
      <participant entity="Conducteur" cardinality="0,N"/>
      <participant entity="Vehicule"   cardinality="0,N"/>
      <participant entity="Trajet"     cardinality="0,N"/>
      <property name="heure_depart" type="Time" nullable="false"/>
      <property name="heure_arrivee" type="Time" nullable="true"/>
    </ternary-association>

  </ternary-associations>

</model>
