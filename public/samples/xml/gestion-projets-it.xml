<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle de test complet — Gestion de Projets IT
  Couvre toutes les fonctionnalités :
    - Associations simples (1,1 / 0,N / 0,N×0,N)
    - Association avec propriétés portées
    - Association réflexive (loopback) — right : Utilisateur "manage" Utilisateur
    - Association réflexive (loopback) — bottom : Tache "bloque" Tache
    - Association ternaire sans CIF : Utilisateur × Tache × Sprint → "affecter"
    - Association ternaire avec CIF : Utilisateur × Projet × Competence → "contribuer" (CIF sur Competence)
-->
<model name="Gestion de Projets IT">

  <entities>

    <entity name="Utilisateur" timestamps="true" softDeletes="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="role" type="String" nullable="false"/>
      <property name="avatar" type="String" nullable="true"/>
    </entity>

    <entity name="Projet" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="date_debut" type="Date" nullable="false"/>
      <property name="date_fin" type="Date" nullable="true"/>
      <property name="statut" type="String" nullable="false"/>
      <property name="budget" type="Decimal" nullable="true"/>
    </entity>

    <entity name="Tache" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="titre" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
      <property name="priorite" type="String" nullable="false"/>
      <property name="statut" type="String" nullable="false"/>
      <property name="points_effort" type="Integer" nullable="true"/>
      <property name="date_echeance" type="Date" nullable="true"/>
    </entity>

    <entity name="Competence" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="categorie" type="String" nullable="true"/>
    </entity>

    <entity name="Sprint" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="numero" type="Integer" nullable="false"/>
      <property name="date_debut" type="Date" nullable="false"/>
      <property name="date_fin" type="Date" nullable="false"/>
      <property name="objectif" type="Text" nullable="true"/>
      <property name="velocite" type="Integer" nullable="true"/>
    </entity>

    <entity name="Client" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom_entreprise" type="String" nullable="false"/>
      <property name="contact" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
    </entity>

  </entities>

  <relationships>

    <!-- ══ ASSOCIATION RÉFLEXIVE (loopback right) ══
         Un utilisateur peut manager un autre utilisateur (hiérarchie d'équipe).
         loopbackSide="right" → arc à droite du nœud Utilisateur. -->
    <relationship name="manager"
                  source="Utilisateur" target="Utilisateur"
                  sourceCardinality="0,1" targetCardinality="0,N"
                  loopbackSide="right"/>

    <!-- ══ ASSOCIATION RÉFLEXIVE (loopback bottom) ══
         Une tâche peut en bloquer une autre (dépendances entre tâches).
         loopbackSide="bottom" → arc en bas du nœud Tache. -->
    <relationship name="bloque"
                  source="Tache" target="Tache"
                  sourceCardinality="0,N" targetCardinality="0,N"
                  loopbackSide="bottom"/>

    <!-- ══ ASSOCIATIONS SIMPLES ══ -->

    <!-- Un client commande plusieurs projets -->
    <relationship name="commander"
                  source="Client" target="Projet"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un projet est découpé en sprints -->
    <relationship name="decouper"
                  source="Projet" target="Sprint"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un projet contient des tâches -->
    <relationship name="contenir"
                  source="Projet" target="Tache"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- ══ ASSOCIATION AVEC PROPRIÉTÉS PORTÉES ══ -->

    <!-- Un utilisateur maîtrise des compétences (avec niveau de maîtrise) -->
    <relationship name="maitriser"
                  source="Utilisateur" target="Competence"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="niveau" type="String" nullable="false"/>
      <property name="date_certification" type="Date" nullable="true"/>
    </relationship>

    <!-- Une tâche requiert des compétences -->
    <relationship name="requierir"
                  source="Tache" target="Competence"
                  sourceCardinality="0,N" targetCardinality="0,N"/>

  </relationships>

  <ternary-associations>

    <!-- ══ ASSOCIATION TERNAIRE SANS CIF ══
         Affecter un utilisateur à une tâche dans un sprint spécifique.
         Aucune CIF : les 3 entités sont librement combinées. -->
    <ternary-association name="affecter">
      <participant entity="Utilisateur" cardinality="0,N"/>
      <participant entity="Tache"       cardinality="0,N"/>
      <participant entity="Sprint"      cardinality="0,N"/>
    </ternary-association>

    <!-- ══ ASSOCIATION TERNAIRE AVEC CIF ══
         Un utilisateur contribue à un projet en mobilisant une compétence.
         CIF sur "Competence" : connaître l'utilisateur et le projet suffit à
         déterminer la compétence mobilisée (dépendance fonctionnelle). -->
    <ternary-association name="contribuer" cif="Competence">
      <participant entity="Utilisateur"  cardinality="0,N"/>
      <participant entity="Projet"       cardinality="0,N"/>
      <participant entity="Competence"   cardinality="0,N"/>
    </ternary-association>

  </ternary-associations>

</model>
