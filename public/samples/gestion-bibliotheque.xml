<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modèle — Gestion de Bibliothèque
  Fonctionnalités couvertes :
    - Types variés : Boolean, DateTime
    - Cardinalité 0,1 (livre peut avoir 0 ou 1 emprunt actif)
    - Association N,N avec propriétés portées (noter)
    - Association réflexive (loopback bottom) : Categorie "sous-catégorie de" Categorie
    - Association simple 1,1 → 0,N classiques
-->
<model name="Gestion de Bibliothèque">

  <entities>

    <entity name="Adherent" timestamps="true" softDeletes="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="email" type="String" nullable="false"/>
      <property name="telephone" type="String" nullable="true"/>
      <property name="date_inscription" type="Date" nullable="false"/>
      <property name="actif" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Livre" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="titre" type="String" nullable="false"/>
      <property name="isbn" type="String" nullable="false"/>
      <property name="annee_publication" type="Integer" nullable="true"/>
      <property name="nombre_pages" type="Integer" nullable="true"/>
      <property name="disponible" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Auteur" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="prenom" type="String" nullable="false"/>
      <property name="nationalite" type="String" nullable="true"/>
      <property name="biographie" type="Text" nullable="true"/>
    </entity>

    <entity name="Categorie" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="description" type="Text" nullable="true"/>
    </entity>

    <entity name="Emprunt" timestamps="true">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="date_emprunt" type="DateTime" nullable="false"/>
      <property name="date_retour_prevue" type="Date" nullable="false"/>
      <property name="date_retour_effective" type="DateTime" nullable="true"/>
      <property name="rendu" type="Boolean" nullable="false"/>
    </entity>

    <entity name="Editeur" timestamps="false">
      <property name="id" type="Big Integer" primaryKey="true" autoIncrement="true" nullable="false"/>
      <property name="nom" type="String" nullable="false"/>
      <property name="pays" type="String" nullable="true"/>
    </entity>

  </entities>

  <relationships>

    <!-- Un éditeur publie plusieurs livres -->
    <relationship name="publier"
                  source="Editeur" target="Livre"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un livre appartient à une catégorie -->
    <relationship name="classer"
                  source="Categorie" target="Livre"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un adhérent effectue des emprunts -->
    <relationship name="effectuer"
                  source="Adherent" target="Emprunt"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un emprunt concerne un livre -->
    <relationship name="concerner"
                  source="Livre" target="Emprunt"
                  sourceCardinality="1,1" targetCardinality="0,N"/>

    <!-- Un livre est écrit par plusieurs auteurs (et inversement) -->
    <relationship name="ecrire"
                  source="Auteur" target="Livre"
                  sourceCardinality="0,N" targetCardinality="0,N"/>

    <!-- Un adhérent note des livres -->
    <relationship name="noter"
                  source="Adherent" target="Livre"
                  sourceCardinality="0,N" targetCardinality="0,N">
      <property name="note" type="Integer" nullable="false"/>
      <property name="commentaire" type="Text" nullable="true"/>
      <property name="date_avis" type="Date" nullable="false"/>
    </relationship>

    <!-- Catégorie réflexive : sous-catégorie -->
    <relationship name="sous-categorie"
                  source="Categorie" target="Categorie"
                  sourceCardinality="0,1" targetCardinality="0,N"
                  loopbackSide="right"/>

  </relationships>

  <ternary-associations/>

</model>
