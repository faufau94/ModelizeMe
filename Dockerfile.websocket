# ============================================
# WebSocket Server - minimal y-websocket image
# ============================================
FROM node:22-alpine

WORKDIR /app

# Install only what the websocket server needs
RUN npm install --omit=dev ws yjs y-websocket@1
RUN echo '{"type":"module"}' > package.json

COPY server/websocket-server.js ./server/

ENV HOST=0.0.0.0
ENV PORT=1234

EXPOSE 1234

CMD ["node", "server/websocket-server.js"]
